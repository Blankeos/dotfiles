{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "Bash(npx tsc:*)",
      "Bash(npm run:*)",
      "Bash(bunx tsc:*)",
      "Bash(bunx run:*)"
    ]
  },
  "hooks": {
    "Notification": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "afplay ~/.config/opencode/plugin/nintendolaunch.mp3 2>/dev/null || true",
            "async": true
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "afplay ~/.config/opencode/plugin/pokeding.wav 2>/dev/null || true",
            "async": true
          }
        ]
      }
    ]
  }
}
