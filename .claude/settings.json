{
  "$schema" : "https:\/\/json.schemastore.org\/claude-code-settings.json",
  "hooks" : {
    "PermissionDenied" : [
      {
        "hooks" : [
          {
            "async" : true,
            "command" : "afplay ~\/.config\/opencode\/plugin\/nintendoerror.mp3 2>\/dev\/null -v 0.3 || true",
            "type" : "command"
          }
        ]
      }
    ],
    "PermissionRequest" : [
      {
        "hooks" : [
          {
            "async" : true,
            "command" : "afplay ~\/.config\/opencode\/plugin\/nintendolaunch.mp3 2>\/dev\/null || true",
            "type" : "command"
          }
        ]
      }
    ],
    "Stop" : [
      {
        "hooks" : [
          {
            "async" : true,
            "command" : "afplay ~\/.config\/opencode\/plugin\/pokeding.wav 2>\/dev\/null || true",
            "type" : "command"
          }
        ]
      }
    ],
    "StopFailure" : [
      {
        "hooks" : [
          {
            "async" : true,
            "command" : "afplay ~\/.config\/opencode\/plugin\/nintendoerror.mp3 2>\/dev\/null -v 0.3 || true",
            "type" : "command"
          }
        ]
      }
    ]
  },
  "permissions" : {
    "allow" : [
      "Read(**)",
      "Write(.\/**)",
      "Bash(**)"
    ],
    "ask" : [
      "Read(**\/.env*)",
      "Read(**\/.gitignore*)",
      "Read(**\/.git\/**)",
      "Read(**\/*.env)",
      "Read(**\/.gitignore)",
      "Read(..\/**)",
      "Read(..\/..\/**)",
      "Read(\/absolute\/paths\/outside\/**)",
      "Write(..\/**)",
      "Write(..\/..\/**)",
      "Write(\/absolute\/paths\/outside\/**)",
      "Bash(rm *)",
      "Bash(rm -**)"
    ],
    "deny" : [
      "Bash(git push**)",
      "Bash(git branch -d**)",
      "Bash(git branch -D**)",
      "Bash(git reset --hard**)",
      "Bash(git clean -f**)",
      "Bash(git rebase -i**)"
    ]
  }
}
