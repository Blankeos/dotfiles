{
  "$schema": "https://opencode.ai/config.json",
  // "plugin": ["opencode-gemini-auth", "@mohak34/opencode-notifier@latest"],
  "plugin": ["@mohak34/opencode-notifier@latest"],
  "provider": {
    "nano-gpt": {
      //   // "npm": "@ai-sdk/openai-compatible",
      //   // "name": "NanoGPT",
      //   // "options": {
      //   //   "baseURL": "https://nano-gpt.com/api/v1",
      //   //   "apiKey": "{env:NANO_GPT_API_KEY}",
      //   // },
      "models": {
        "z-ai/glm-4.6v": { "name": "GLM 4.6V" },
        "zai-org/glm-4.7-flash-original": { "name": "GLM 4.7 Flash Original" },
      },
    },
    "ollama-cloud": {
      "models": {
        "minimax-m2.7": { "name": "MiniMax M2.7" },
      },
    },
  },
  "mcp": {
    // Commented because I just use agent-browser (By Vercel)
    // "playwright": {
    //   "type": "local",
    //   "command": ["bunx", "@playwright/mcp@latest"],
    //   "enabled": false,
    // },
    // "tavily": {
    //   "type": "remote",
    //   "url": "https://mcp.tavily.com/mcp/?tavilyApiKey={env:TAVILY_API_KEY}",
    //   "oauth": false,
    //   "headers": {
    //     "Authorization": "Bearer {env:TAVILY_API_KEY}",
    //   },
    //   "enabled": true,
    // },
  },
  "agent": {
    "vlm-agent": {
      "mode": "subagent",
      "description": "For non-vision models to analyze images. Before calling this agent, ALWAYS run extract_images tool first to save session images to /tmp/opencode-images/ then pass the resulting file paths in your prompt so this agent can read them.",
      // "model": "fireworks-ai/accounts/fireworks/models/kimi-k2p5",
      "model": "opencode-go/kimi-k2.6",
      "prompt": "You are an expert frontend developer specializing in modern UI/UX design and a skilled image analyst. Do not install any other library, just use your vision capability. You can either analyze provided images to describe their content, layout, and visual details, or perform frontend development tasks based on those descriptions or direct instructions.",
      "permission": {
        "read": { "/tmp/opencode-images/*": "allow" },
        "write": { "/tmp/opencode-images/*": "allow" },
      },
    },
  },
}
